CORS_ORIGINS=http://localhost:5173
MAX_UPLOAD_MB=500
RATE_LIMIT=10/minute
LOG_LEVEL=INFO
DEVICE=
STORAGE_DIR=

CLIP_MODEL_NAME=openai/clip-vit-base-patch32
DETECTOR_MODEL_NAME=IDEA-Research/grounding-dino-base

DETECTOR_BACKEND=yolo_world
YOLO_WORLD_DEFAULT=large
# Fallback chain: large,medium,small (tried in order on failure)
YOLO_WORLD_FALLBACKS=large,medium,small

# Phase 5: 6-signal hybrid scoring weights (roadmap §6.1)
CLIP_WEIGHT=0.20
CAPTION_WEIGHT=0.20
OBJECT_MATCH_WEIGHT=0.25
MOTION_MATCH_WEIGHT=0.10
TRACK_CONSISTENCY_WEIGHT=0.15
TEMPORAL_WEIGHT=0.10
# backward-compat aliases
SEMANTIC_WEIGHT=0.55
OBJECT_WEIGHT=0.45

DETECTION_THRESHOLD=0.2
SEARCH_HIGH_THRESHOLD=0.25
SEARCH_MEDIUM_THRESHOLD=0.15
GAP_THRESHOLD=3
MOTION_STRIDE=3
MOTION_TARGET_PCT=5.0
BATCH_SIZE=64
NUM_WORKERS=4
THUMBNAIL_QUALITY=80
DET_CACHE_MAXSIZE=5000
DET_CACHE_TTL=3600
FAISS_IVF_THRESHOLD=50

# Phase 1: Object detection during indexing
# Comma-separated list of objects YOLO-World detects per keyframe
INDEX_DETECTION_PROMPTS=person, car, bicycle, motorcycle, bus, truck, traffic light, fire hydrant, stop sign, parking meter, bench, bird, cat, dog, horse, sheep, cow, elephant, bear, zebra, giraffe, backpack, umbrella, handbag, tie, suitcase, frisbee, skis, snowboard, sports ball, kite, baseball bat, baseball glove, skateboard, surfboard, tennis racket, bottle, wine glass, cup, fork, knife, spoon, bowl, banana, apple, sandwich, orange, broccoli, carrot, hot dog, pizza, donut, cake, chair, couch, potted plant, bed, dining table, toilet, tv, laptop, mouse, remote, keyboard, cell phone, microwave, oven, toaster, sink, refrigerator, book, clock, vase, scissors, teddy bear, hair drier, toothbrush
INDEX_MIN_FPS=5
INDEX_OBJECT_CONFIDENCE=0.3
INDEX_OBJECT_EMBED_DIM=512

# Phase 2: Object tracking
TRACK_MATCH_THRESHOLD=0.5
TRACK_BUFFER=30
TRACK_CONSISTENCY_WEIGHT=0.10

# Phase 3: Scene captioning (optional, requires ~800MB Florence-2 model download)
# CAPTIONER_MODEL=microsoft/Florence-2-base
# CAPTIONER_ENABLED=true
QUERY_PARSER_MODE=regex

# Phase 4: Clip-level indexing for temporal/action queries
# Sliding window over keyframes: group N consecutive keyframes into a clip
CLIP_WINDOW_SIZE=3
CLIP_STRIDE=2
# Blend between averaged frame embedding (1 - weight) and motion stats (weight)
CLIP_MOTION_WEIGHT=0.3

# Phase 5: Cross-encoder reranking (Stage 4, optional, requires sentence-transformers)
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_ENABLED=true

API_KEY=
STORAGE_CLEANUP_DAYS=7
REQUEST_TIMEOUT_SECONDS=120
